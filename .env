# API — points at the production backend by default
# To switch to local: change VITE_API_BASE_URL to http://localhost:8000
# VITE_API_BASE_URL=https://university-api-production.up.railway.app
VITE_API_TIMEOUT=10000

# App
VITE_APP_NAME=UAMD University Portal
VITE_APP_VERSION=1.0.0

# Auth token keys (used by storage.js)
VITE_TOKEN_KEY=uamd_access_token
VITE_REFRESH_TOKEN_KEY=uamd_refresh_token

# Feature flags
VITE_ENABLE_REGISTRATION=false
VITE_MAINTENANCE_MODE=false